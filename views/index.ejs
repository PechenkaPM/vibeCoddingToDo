<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo MVP</title>
    <link rel="stylesheet" href="<%= page.assetPaths.stylesheet %>" />
  </head>
  <body>
    <% const completionRate = page.stats.total === 0 ? 0 : Math.round((page.stats.completed / page.stats.total) * 100); %>
    <div class="page-shell">
      <div class="ambient-orb ambient-orb-left"></div>
      <div class="ambient-orb ambient-orb-right"></div>
      <main class="app-card">
        <section class="hero">
          <p class="eyebrow">VibeCoddedToDo <%= page.buildType %></p>
          <h1>Organize the day without the clutter.</h1>
          <p class="hero-copy">
            A focused todo board for small lab tasks, quick wins, and the next thing
            you actually need to finish.
          </p>
          <div class="hero-strip">
            <div class="hero-chip">
              <span class="chip-label">Completion</span>
              <strong><%= completionRate %>%</strong>
            </div>
            <div class="hero-chip">
              <span class="chip-label">Focus</span>
              <strong><%= page.stats.remaining === 0 && page.stats.total > 0 ? "Clear" : "In Motion" %></strong>
            </div>
          </div>
        </section>

        <section class="composer">
          <form action="/todos" method="post" class="composer-form" data-testid="todo-form">
            <label class="sr-only" for="title">New task</label>
            <input
              id="title"
              name="title"
              type="text"
              maxlength="<%= page.titleLimit %>"
              placeholder="Add a task worth finishing..."
              value="<%= page.draftTitle %>"
              autocomplete="off"
              required
            />
            <button type="submit">Add Task</button>
            <a href="/debug-sentry" style="margin-left:10px;padding:10px 14px;background:#e03e2f;color:#fff;border-radius:10px;text-decoration:none;font-weight:600;">
                Trigger error
            </a>
          </form>
          <div class="composer-meta">
            <article class="stat-pill" data-testid="stat-open">
              <span class="stat-kicker">Open</span>
              <strong><%= page.stats.remaining %></strong>
            </article>
            <article class="stat-pill" data-testid="stat-done">
              <span class="stat-kicker">Done</span>
              <strong><%= page.stats.completed %></strong>
            </article>
            <article class="stat-pill" data-testid="stat-total">
              <span class="stat-kicker">Total</span>
              <strong><%= page.stats.total %></strong>
            </article>
          </div>
          <div class="progress-track" aria-hidden="true">
            <span class="progress-fill" style="width: <%= completionRate %>%"></span>
          </div>
          <% if (page.errorMessage) { %>
            <p class="status-message"><%= page.errorMessage %></p>
          <% } %>
        </section>

        <section class="todo-panel">
          <div class="panel-head">
            <div>
              <h2>Tasks</h2>
              <p>Click a checkbox to complete. Remove anything that no longer matters.</p>
            </div>
            <span class="panel-badge"><%= page.stats.total %> items</span>
          </div>

          <% if (page.todos.length === 0) { %>
            <div class="empty-state">
              <div class="empty-icon"></div>
              <strong>No tasks yet.</strong>
              <span>Start with one clear next action.</span>
            </div>
          <% } else { %>
            <ul class="todo-list" data-testid="todo-list">
              <% page.todos.forEach((todo) => { %>
                <li
                  class="todo-item <%= todo.isCompleted ? 'is-complete' : '' %>"
                  data-testid="todo-item"
                  data-title="<%= todo.title %>"
                >
                  <form action="/todos/<%= todo.id %>/toggle" method="post">
                    <button
                      type="submit"
                      class="toggle-button"
                      data-testid="toggle-todo"
                      aria-label="<%= todo.isCompleted ? 'Mark as active' : 'Mark as complete' %>"
                    >
                      <span></span>
                    </button>
                  </form>

                  <div class="todo-copy">
                    <p><%= todo.title %></p>
                    <small>
                      Added <%= new Date(todo.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric" }) %>
                    </small>
                  </div>

                  <div class="todo-actions">
                    <span class="state-pill <%= todo.isCompleted ? 'is-complete' : 'is-active' %>">
                      <%= todo.isCompleted ? "Done" : "Active" %>
                    </span>
                    <form action="/todos/<%= todo.id %>/delete" method="post">
                      <button type="submit" class="delete-button" data-testid="delete-todo">Delete</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>
      </main>
    </div>
